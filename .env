# 1. 开启渠道模式，声明这里有两个渠道：deepseek 和 aihubmix
LLM_CHANNELS=gemini,openai

# 2. 渠道一：配置 gemini 官方
GEMINI_API_KEY=AIzaSyB8mXL8uwjOE3FjqqbfXE3quBQaQAweEQc

# 3. 渠道二：填入平台提供给你的 API Key
OPENAI_API_KEY=sk-cZuDbVADmnBedhokBrZZHpHee7cRcQyBC2fJvtiLR2z2QE17
# 填入平台的接口地址 (非常重要：结尾通常必须带有 /v1)
OPENAI_BASE_URL=https://newapi.arealms.org/v1

# 4. 【关键】指定主模型和备用模型列表
# 平时首选用 gemini 这款模型：
LITELLM_MODEL=gemini/gemini-3-flash
# 主模型崩了立刻挨个尝试下面这俩备用模型：
LITELLM_FALLBACK_MODELS=gemini/gemini-2.5-flash,openai/gpt-5.2
